generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Company {
  id                      String                   @id @default(uuid())
  sourceSystem            String
  sourceTenantId          String
  name                    String
  document                String?
  status                  String                   @default("ACTIVE")
  interestRate            Float?
  interestGracePeriod     Int?
  penaltyRate             Float?
  penaltyValue            Float?
  penaltyGracePeriod      Int?
  createdAt               DateTime                 @default(now())
  createdBy               String?
  updatedAt               DateTime                 @updatedAt
  updatedBy               String?
  canceledAt              DateTime?
  canceledBy              String?
  bankAccounts            BankAccount[]
  fiscalCertificates      FiscalCertificate[]
  nfceProfiles            NfceProfile[]
  fiscalDocuments         FiscalDocument[]
  fiscalDocumentAttempts  FiscalDocumentAttempt[]
  products                Product[]
  suppliers               Supplier[]
  parties                 Party[]
  payableInvoiceImports   PayableInvoiceImport[]
  payableTitles           PayableTitle[]
  payableInstallments     PayableInstallment[]
  stockMovements          StockMovement[]
  productStockBalances    ProductStockBalance[]
  receivableBatches       ReceivableBatch[]
  receivableTitles        ReceivableTitle[]
  receivableInstallments  ReceivableInstallment[]
  bankReturnImports       BankReturnImport[]
  bankReturnImportItems   BankReturnImportItem[]
  bankStatementImports    BankStatementImport[]
  bankStatementMovements  BankStatementMovement[]
  bankDdaRecords          BankDdaRecord[]
  bankDdaAuditEvents      BankDdaAuditEvent[]
  cashSessions            CashSession[]
  cashMovements           CashMovement[]
  settlements             InstallmentSettlement[]
  customerCredits         CustomerCredit[]
  customerCreditMovements CustomerCreditMovement[]
  branches                CompanyBranch[]
  sales                   Sale[]
  saleReturns             SaleReturn[]
  saleItems               SaleItem[]
  saleReturnItems         SaleReturnItem[]
  salePayments            SalePayment[]
  salePixIntents          SalePixIntent[]
  receivablePixIntents    ReceivablePixIntent[]
  screenParameters        ScreenParameter[]
  superTefConfigurations  SuperTefConfiguration[]
  superTefTerminals       SuperTefTerminal[]
  superTefCheckouts       SuperTefCheckout[]
  superTefCheckoutRoutes  SuperTefCheckoutRoute[]
  superTefPayments        SuperTefPayment[]
  superTefAuditEvents     SuperTefAuditEvent[]

  @@unique([sourceSystem, sourceTenantId])
  @@index([name])
  @@map("companies")
}

model CompanyBranch {
  id                         String    @id @default(uuid())
  companyId                  String
  branchCode                 Int
  name                       String
  isActive                   Boolean   @default(true)
  isDefault                  Boolean   @default(false)
  inventoryControlType       String    @default("TRADITIONAL")
  quantityPrecision          String    @default("INTEGER_ONLY")
  stockControlMode           String    @default("BY_PRODUCT")
  stockIntegerQuantityMode   String    @default("BY_PRODUCT")
  stockLotControlMode        String    @default("BY_PRODUCT")
  stockExpirationControlMode String    @default("BY_PRODUCT")
  stockGridControlMode       String    @default("BY_PRODUCT")
  stockNegativeControlMode   String    @default("BY_PRODUCT")
  allowSaleUnitPriceEdit     Boolean   @default(true)
  allowSaleItemDiscount      Boolean   @default(true)
  createdAt                  DateTime  @default(now())
  createdBy                  String?
  updatedAt                  DateTime  @updatedAt
  updatedBy                  String?
  canceledAt                 DateTime?
  canceledBy                 String?

  company          Company           @relation(fields: [companyId], references: [id], onDelete: Restrict)
  screenParameters ScreenParameter[]

  @@unique([companyId, branchCode])
  @@index([companyId, isActive, name])
  @@map("company_branches")
}

model ScreenParameter {
  id             String    @id @default(uuid())
  companyId      String
  branchId       String
  screenId       String
  parametersJson String
  createdAt      DateTime  @default(now())
  createdBy      String?
  updatedAt      DateTime  @updatedAt
  updatedBy      String?
  canceledAt     DateTime?
  canceledBy     String?

  company Company       @relation(fields: [companyId], references: [id], onDelete: Restrict)
  branch  CompanyBranch @relation(fields: [branchId], references: [id], onDelete: Restrict)

  @@unique([companyId, branchId, screenId])
  @@index([companyId, branchId, screenId, canceledAt])
  @@map("screen_parameters")
}

model SuperTefConfiguration {
  id                      String    @id @default(uuid())
  companyId               String
  branchCode              Int       @default(1)
  provider                String    @default("SUPERTEF")
  status                  String    @default("INACTIVE")
  environment             String    @default("HOMOLOGATION")
  clientKey               String
  accessTokenEncrypted    String
  tokenFingerprint        String
  tokenHint               String
  printReceipt            Boolean   @default(true)
  operationTimeoutSeconds Int       @default(120)
  pollIntervalSeconds     Int       @default(4)
  lastConnectionTestAt    DateTime?
  lastConnectionStatus    String?
  lastConnectionMessage   String?
  lastPosSyncAt           DateTime?
  createdAt               DateTime  @default(now())
  createdBy               String?
  updatedAt               DateTime  @updatedAt
  updatedBy               String?
  canceledAt              DateTime?
  canceledBy              String?

  company   Company            @relation(fields: [companyId], references: [id], onDelete: Restrict)
  terminals SuperTefTerminal[]
  payments  SuperTefPayment[]

  @@unique([companyId, branchCode, provider])
  @@index([companyId, branchCode, status, canceledAt])
  @@map("supertef_configurations")
}

model SuperTefTerminal {
  id                String    @id @default(uuid())
  configurationId   String
  companyId         String
  branchCode        Int       @default(1)
  providerPosId     Int
  operationalStatus String    @default("ACTIVE")
  providerStatus    Int?
  name              String
  brand             String?
  model             String?
  bank              String?
  providerClientId  Int?
  providerCreatedAt DateTime?
  providerUpdatedAt DateTime?
  activatedAt       DateTime?
  lastSeenAt        DateTime?
  lastSyncedAt      DateTime?
  createdAt         DateTime  @default(now())
  createdBy         String?
  updatedAt         DateTime  @updatedAt
  updatedBy         String?
  canceledAt        DateTime?
  canceledBy        String?

  configuration  SuperTefConfiguration   @relation(fields: [configurationId], references: [id], onDelete: Restrict)
  company        Company                 @relation(fields: [companyId], references: [id], onDelete: Restrict)
  checkoutRoutes SuperTefCheckoutRoute[]
  payments       SuperTefPayment[]

  @@unique([configurationId, providerPosId])
  @@index([companyId, branchCode, operationalStatus, canceledAt])
  @@map("supertef_terminals")
}

model SuperTefCheckout {
  id         String    @id @default(uuid())
  companyId  String
  branchCode Int       @default(1)
  code       String
  name       String
  status     String    @default("ACTIVE")
  createdAt  DateTime  @default(now())
  createdBy  String?
  updatedAt  DateTime  @updatedAt
  updatedBy  String?
  canceledAt DateTime?
  canceledBy String?

  company  Company                 @relation(fields: [companyId], references: [id], onDelete: Restrict)
  routes   SuperTefCheckoutRoute[]
  payments SuperTefPayment[]

  @@unique([companyId, branchCode, code])
  @@index([companyId, branchCode, status, canceledAt])
  @@map("supertef_checkouts")
}

model SuperTefCheckoutRoute {
  id         String    @id @default(uuid())
  companyId  String
  branchCode Int       @default(1)
  checkoutId String
  terminalId String
  priority   Int
  status     String    @default("ACTIVE")
  createdAt  DateTime  @default(now())
  createdBy  String?
  updatedAt  DateTime  @updatedAt
  updatedBy  String?
  canceledAt DateTime?
  canceledBy String?

  company  Company          @relation(fields: [companyId], references: [id], onDelete: Restrict)
  checkout SuperTefCheckout @relation(fields: [checkoutId], references: [id], onDelete: Restrict)
  terminal SuperTefTerminal @relation(fields: [terminalId], references: [id], onDelete: Restrict)

  @@unique([checkoutId, terminalId])
  @@index([companyId, branchCode, checkoutId, status, priority])
  @@index([companyId, branchCode, terminalId, status])
  @@map("supertef_checkout_routes")
}

model SuperTefAuditEvent {
  id           String   @id @default(uuid())
  companyId    String
  branchCode   Int      @default(1)
  entityType   String
  entityId     String?
  action       String
  summary      String
  beforeJson   String?
  afterJson    String?
  metadataJson String?
  occurredAt   DateTime @default(now())
  performedBy  String?
  createdAt    DateTime @default(now())
  createdBy    String?

  company Company @relation(fields: [companyId], references: [id], onDelete: Restrict)

  @@index([companyId, branchCode, occurredAt])
  @@index([companyId, branchCode, entityType, entityId])
  @@map("supertef_audit_events")
}

model SuperTefPayment {
  id                      String    @id @default(uuid())
  configurationId         String
  companyId               String
  branchCode              Int       @default(1)
  terminalId              String
  checkoutId              String?
  operationId             String
  providerPaymentUniqueId String?
  providerPaymentStatus   Int?
  status                  String    @default("PENDING_SEND")
  transactionType         String
  installmentType         Int       @default(1)
  installmentCount        Int       @default(1)
  amount                  Float
  orderId                 String
  description             String
  purpose                 String    @default("MANUAL")
  businessReference       String?
  printReceipt            Boolean   @default(true)
  paymentMessage          String?
  paymentOrderJson        String?
  paymentDataJson         String?
  terminalLockKey         String?   @unique
  requestedAt             DateTime  @default(now())
  lastPolledAt            DateTime?
  completedAt             DateTime?
  appliedEntityType       String?
  appliedEntityId         String?
  appliedAt               DateTime?
  createdAt               DateTime  @default(now())
  createdBy               String?
  updatedAt               DateTime  @updatedAt
  updatedBy               String?
  canceledAt              DateTime?
  canceledBy              String?

  configuration SuperTefConfiguration   @relation(fields: [configurationId], references: [id], onDelete: Restrict)
  company       Company                 @relation(fields: [companyId], references: [id], onDelete: Restrict)
  terminal      SuperTefTerminal        @relation(fields: [terminalId], references: [id], onDelete: Restrict)
  checkout      SuperTefCheckout?       @relation(fields: [checkoutId], references: [id], onDelete: Restrict)
  salePayments  SalePayment[]
  settlements   InstallmentSettlement[]

  @@unique([companyId, branchCode, operationId])
  @@unique([configurationId, providerPaymentUniqueId])
  @@index([companyId, branchCode, status, requestedAt])
  @@index([companyId, branchCode, terminalId, status])
  @@index([companyId, branchCode, purpose, businessReference])
  @@index([companyId, branchCode, appliedEntityType, appliedEntityId])
  @@map("supertef_payments")
}

model Product {
  id                    String    @id @default(uuid())
  companyId             String
  branchCode            Int       @default(1)
  status                String    @default("ACTIVE")
  name                  String
  internalCode          String?
  sku                   String?
  barcode               String?
  unitCode              String    @default("UN")
  productType           String    @default("GOODS")
  tracksInventory       Boolean   @default(true)
  allowFraction         Boolean   @default(false)
  usesColorSize         Boolean   @default(false)
  usesLotControl        Boolean   @default(false)
  usesExpirationControl Boolean   @default(false)
  allowsNegativeStock   Boolean   @default(false)
  currentStock          Float     @default(0)
  minimumStock          Float     @default(0)
  purchasePrice         Float?
  salePrice             Float?
  ncmCode               String?
  cestCode              String?
  notes                 String?
  createdAt             DateTime  @default(now())
  createdBy             String?
  updatedAt             DateTime  @updatedAt
  updatedBy             String?
  canceledAt            DateTime?
  canceledBy            String?

  company                   Company                    @relation(fields: [companyId], references: [id], onDelete: Restrict)
  payableInvoiceImportItems PayableInvoiceImportItem[]
  stockMovements            StockMovement[]
  stockBalances             ProductStockBalance[]
  saleItems                 SaleItem[]
  saleReturnItems           SaleReturnItem[]

  @@unique([companyId, branchCode, internalCode])
  @@unique([companyId, branchCode, sku])
  @@unique([companyId, branchCode, barcode])
  @@index([companyId, status, name])
  @@index([companyId, productType, tracksInventory])
  @@map("products")
}

model ProductStockBalance {
  id                String    @id @default(uuid())
  companyId         String
  branchCode        Int       @default(0)
  productId         String
  variantKey        String    @default("GERAL")
  colorCode         String?
  colorName         String?
  sizeCode          String?
  lotNumber         String?
  lotExpirationDate DateTime?
  quantity          Float     @default(0)
  reservedQuantity  Float     @default(0)
  createdAt         DateTime  @default(now())
  createdBy         String?
  updatedAt         DateTime  @updatedAt
  updatedBy         String?
  canceledAt        DateTime?
  canceledBy        String?

  company Company @relation(fields: [companyId], references: [id], onDelete: Restrict)
  product Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@unique([companyId, productId, branchCode, variantKey])
  @@index([companyId, branchCode, productId])
  @@index([companyId, productId, lotNumber])
  @@map("product_stock_balances")
}

model FiscalCertificate {
  id                 String    @id @default(uuid())
  companyId          String
  branchCode         Int       @default(1)
  status             String    @default("ACTIVE")
  certificateType    String    @default("A1")
  environment        String    @default("PRODUCTION")
  purpose            String    @default("NFE_DFE")
  isDefault          Boolean   @default(false)
  aliasName          String
  authorStateCode    String
  holderName         String
  holderDocument     String
  serialNumber       String?
  thumbprint         String?
  validFrom          DateTime?
  validTo            DateTime?
  pfxEncryptedBase64 String
  passwordEncrypted  String
  lastNsu            String?
  lastMaxNsu         String?
  lastSyncAt         DateTime?
  lastSyncStatus     String?
  lastSyncMessage    String?
  createdAt          DateTime  @default(now())
  createdBy          String?
  updatedAt          DateTime  @updatedAt
  updatedBy          String?
  canceledAt         DateTime?
  canceledBy         String?

  company               Company                @relation(fields: [companyId], references: [id], onDelete: Restrict)
  payableInvoiceImports PayableInvoiceImport[]
  nfceProfiles          NfceProfile[]
  fiscalDocuments       FiscalDocument[]

  @@index([companyId, status, environment, purpose, aliasName])
  @@map("fiscal_certificates")
}

model Supplier {
  id                String    @id @default(uuid())
  companyId         String
  branchCode        Int       @default(1)
  status            String    @default("ACTIVE")
  legalName         String
  tradeName         String?
  document          String?
  stateRegistration String?
  email             String?
  phone             String?
  notes             String?
  createdAt         DateTime  @default(now())
  createdBy         String?
  updatedAt         DateTime  @updatedAt
  updatedBy         String?
  canceledAt        DateTime?
  canceledBy        String?

  company               Company                @relation(fields: [companyId], references: [id], onDelete: Restrict)
  payableInvoiceImports PayableInvoiceImport[]
  payableTitles         PayableTitle[]

  @@unique([companyId, branchCode, document])
  @@index([companyId, status, legalName])
  @@map("suppliers")
}

model PayableInvoiceImport {
  id                  String    @id @default(uuid())
  companyId           String
  branchCode          Int       @default(1)
  supplierId          String?
  fiscalCertificateId String?
  status              String    @default("PENDING_APPROVAL")
  importType          String    @default("XML_UPLOAD")
  documentModel       String
  accessKey           String
  invoiceNumber       String
  series              String?
  operationNature     String?
  issueDate           DateTime
  entryDate           DateTime?
  totalProductsAmount Float     @default(0)
  totalInvoiceAmount  Float     @default(0)
  xmlHash             String
  xmlContentBlob      Bytes
  distributionNsu     String?
  parsedSnapshotJson  String?
  approvalNotes       String?
  cancellationReason  String?
  approvedAt          DateTime?
  approvedBy          String?
  createdAt           DateTime  @default(now())
  createdBy           String?
  updatedAt           DateTime  @updatedAt
  updatedBy           String?
  canceledAt          DateTime?
  canceledBy          String?

  company           Company                           @relation(fields: [companyId], references: [id], onDelete: Restrict)
  supplier          Supplier?                         @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  fiscalCertificate FiscalCertificate?                @relation(fields: [fiscalCertificateId], references: [id], onDelete: SetNull)
  items             PayableInvoiceImportItem[]
  installments      PayableInvoiceImportInstallment[]
  payableTitle      PayableTitle?
  stockMovements    StockMovement[]

  @@unique([companyId, branchCode, accessKey])
  @@unique([companyId, branchCode, xmlHash])
  @@index([companyId, status, issueDate])
  @@index([companyId, invoiceNumber, series])
  @@index([fiscalCertificateId, distributionNsu])
  @@map("payable_invoice_imports")
}

model PayableInvoiceImportItem {
  id                         String    @id @default(uuid())
  invoiceImportId            String
  productId                  String?
  lineNumber                 Int
  approvalAction             String?
  supplierItemCode           String?
  barcode                    String?
  description                String
  ncmCode                    String?
  cfopCode                   String?
  unitCode                   String?
  quantity                   Float     @default(0)
  unitPrice                  Float     @default(0)
  totalPrice                 Float     @default(0)
  tracksInventory            Boolean   @default(true)
  draftProductName           String?
  draftInternalCode          String?
  draftSku                   String?
  draftBarcode               String?
  draftUnitCode              String?
  draftProductType           String?
  draftTracksInventory       Boolean?
  draftAllowFraction         Boolean?
  draftUsesLotControl        Boolean?
  draftUsesExpirationControl Boolean?
  draftUsesColorSize         Boolean?
  draftAllowsNegativeStock   Boolean?
  draftMinimumStock          Float?
  draftNotes                 String?
  productCheckedAt           DateTime?
  productCheckedBy           String?
  createdAt                  DateTime  @default(now())
  createdBy                  String?
  updatedAt                  DateTime  @updatedAt
  updatedBy                  String?
  canceledAt                 DateTime?
  canceledBy                 String?

  invoiceImport  PayableInvoiceImport @relation(fields: [invoiceImportId], references: [id], onDelete: Restrict)
  product        Product?             @relation(fields: [productId], references: [id], onDelete: SetNull)
  stockMovements StockMovement[]

  @@unique([invoiceImportId, lineNumber])
  @@index([productId])
  @@map("payable_invoice_import_items")
}

model PayableInvoiceImportInstallment {
  id                String    @id @default(uuid())
  invoiceImportId   String
  installmentLabel  String?
  installmentNumber Int
  dueDate           DateTime
  originalAmount    Float     @default(0)
  additionAmount    Float     @default(0)
  discountAmount    Float     @default(0)
  finalAmount       Float     @default(0)
  amount            Float     @default(0)
  status            String    @default("OPEN")
  paymentMethod     String?
  settledAt         DateTime?
  notes             String?
  createdAt         DateTime  @default(now())
  createdBy         String?
  updatedAt         DateTime  @updatedAt
  updatedBy         String?
  canceledAt        DateTime?
  canceledBy        String?

  invoiceImport PayableInvoiceImport @relation(fields: [invoiceImportId], references: [id], onDelete: Restrict)

  @@unique([invoiceImportId, installmentNumber])
  @@index([dueDate])
  @@map("payable_invoice_import_installments")
}

model PayableTitle {
  id                       String    @id @default(uuid())
  companyId                String
  branchCode               Int       @default(1)
  supplierId               String?
  sourceDocumentType       String
  sourceDocumentId         String    @unique
  status                   String    @default("OPEN")
  documentNumber           String
  description              String
  issueDate                DateTime
  totalAmount              Float     @default(0)
  supplierNameSnapshot     String
  supplierDocumentSnapshot String?
  createdAt                DateTime  @default(now())
  createdBy                String?
  updatedAt                DateTime  @updatedAt
  updatedBy                String?
  canceledAt               DateTime?
  canceledBy               String?

  company      Company              @relation(fields: [companyId], references: [id], onDelete: Restrict)
  supplier     Supplier?            @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  sourceImport PayableInvoiceImport @relation(fields: [sourceDocumentId], references: [id], onDelete: Restrict)
  installments PayableInstallment[]

  @@unique([companyId, branchCode, sourceDocumentType, sourceDocumentId])
  @@index([companyId, status, issueDate])
  @@map("payable_titles")
}

model PayableInstallment {
  id                       String    @id @default(uuid())
  companyId                String
  branchCode               Int       @default(1)
  titleId                  String
  installmentNumber        Int
  installmentCount         Int
  dueDate                  DateTime
  originalAmount           Float     @default(0)
  additionAmount           Float     @default(0)
  discountAmount           Float     @default(0)
  finalAmount              Float     @default(0)
  amount                   Float     @default(0)
  openAmount               Float     @default(0)
  paidAmount               Float     @default(0)
  status                   String    @default("OPEN")
  paymentMethod            String?
  settledAt                DateTime?
  notes                    String?
  descriptionSnapshot      String
  supplierNameSnapshot     String
  supplierDocumentSnapshot String?
  createdAt                DateTime  @default(now())
  createdBy                String?
  updatedAt                DateTime  @updatedAt
  updatedBy                String?
  canceledAt               DateTime?
  canceledBy               String?

  company Company      @relation(fields: [companyId], references: [id], onDelete: Restrict)
  title   PayableTitle @relation(fields: [titleId], references: [id], onDelete: Restrict)

  @@unique([titleId, installmentNumber])
  @@index([companyId, status, dueDate])
  @@map("payable_installments")
}

model StockMovement {
  id                 String    @id @default(uuid())
  companyId          String
  branchCode         Int       @default(1)
  productId          String
  sourceImportId     String?
  sourceImportItemId String?
  sourceType         String    @default("PAYABLE_IMPORT")
  sourceId           String?
  sourceItemId       String?
  movementType       String
  quantity           Float     @default(0)
  previousStock      Float     @default(0)
  resultingStock     Float     @default(0)
  unitCost           Float?
  notes              String?
  occurredAt         DateTime
  createdAt          DateTime  @default(now())
  createdBy          String?
  updatedAt          DateTime  @updatedAt
  updatedBy          String?
  canceledAt         DateTime?
  canceledBy         String?

  company          Company                   @relation(fields: [companyId], references: [id], onDelete: Restrict)
  product          Product                   @relation(fields: [productId], references: [id], onDelete: Restrict)
  sourceImport     PayableInvoiceImport?     @relation(fields: [sourceImportId], references: [id], onDelete: Restrict)
  sourceImportItem PayableInvoiceImportItem? @relation(fields: [sourceImportItemId], references: [id], onDelete: Restrict)

  @@index([companyId, occurredAt])
  @@index([productId, occurredAt])
  @@index([sourceImportId])
  @@index([companyId, sourceType, sourceId])
  @@map("stock_movements")
}

model Sale {
  id                       String    @id @default(uuid())
  companyId                String
  branchCode               Int       @default(1)
  sourceSystem             String
  sourceTenantId           String
  saleNumber               String
  saleChannel              String    @default("GENERAL")
  status                   String    @default("CONFIRMED")
  customerPartyId          String?
  customerNameSnapshot     String
  customerDocumentSnapshot String?
  sourceEntityType         String?
  sourceEntityId           String?
  sourceEntityName         String?
  subtotalAmount           Float     @default(0)
  discountAmount           Float     @default(0)
  totalAmount              Float     @default(0)
  paidAmount               Float     @default(0)
  receivableAmount         Float     @default(0)
  paymentSummary           String?
  receivableBatchId        String?
  receivableTitleId        String?
  notes                    String?
  confirmedAt              DateTime  @default(now())
  createdAt                DateTime  @default(now())
  createdBy                String?
  updatedAt                DateTime  @updatedAt
  updatedBy                String?
  canceledAt               DateTime?
  canceledBy               String?

  company         Company          @relation(fields: [companyId], references: [id], onDelete: Restrict)
  customerParty   Party?           @relation(fields: [customerPartyId], references: [id], onDelete: SetNull)
  receivableTitle ReceivableTitle? @relation(fields: [receivableTitleId], references: [id], onDelete: SetNull)
  items           SaleItem[]
  payments        SalePayment[]
  returns         SaleReturn[]
  fiscalDocument  FiscalDocument?

  @@unique([companyId, branchCode, saleNumber])
  @@index([companyId, branchCode, status, confirmedAt])
  @@index([companyId, saleChannel, confirmedAt])
  @@index([companyId, customerPartyId])
  @@index([receivableTitleId])
  @@map("sales")
}

model SaleItem {
  id                    String    @id @default(uuid())
  companyId             String
  branchCode            Int       @default(1)
  saleId                String
  productId             String
  lineNumber            Int
  productNameSnapshot   String
  productCodeSnapshot   String?
  unitCodeSnapshot      String
  quantity              Float
  unitCost              Float?
  unitPrice             Float
  discountAmount        Float     @default(0)
  totalAmount           Float
  tracksInventory       Boolean   @default(false)
  allowFraction         Boolean   @default(false)
  usesColorSize         Boolean   @default(false)
  usesLotControl        Boolean   @default(false)
  usesExpirationControl Boolean   @default(false)
  allowsNegativeStock   Boolean   @default(false)
  variantKey            String    @default("GERAL")
  colorCode             String?
  colorName             String?
  sizeCode              String?
  lotNumber             String?
  lotExpirationDate     DateTime?
  previousStock         Float?
  resultingStock        Float?
  createdAt             DateTime  @default(now())
  createdBy             String?
  updatedAt             DateTime  @updatedAt
  updatedBy             String?
