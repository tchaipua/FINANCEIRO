generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Company {
  id                     String                  @id @default(uuid())
  sourceSystem           String
  sourceTenantId         String
  name                   String
  document               String?
  status                 String                  @default("ACTIVE")
  interestRate           Float?
  interestGracePeriod    Int?
  penaltyRate            Float?
  penaltyValue           Float?
  penaltyGracePeriod     Int?
  createdAt              DateTime                @default(now())
  createdBy              String?
  updatedAt              DateTime                @updatedAt
  updatedBy              String?
  canceledAt             DateTime?
  canceledBy             String?
  bankAccounts           BankAccount[]
  fiscalCertificates     FiscalCertificate[]
  products               Product[]
  suppliers              Supplier[]
  parties                Party[]
  payableInvoiceImports  PayableInvoiceImport[]
  payableTitles          PayableTitle[]
  payableInstallments    PayableInstallment[]
  stockMovements         StockMovement[]
  receivableBatches      ReceivableBatch[]
  receivableTitles       ReceivableTitle[]
  receivableInstallments ReceivableInstallment[]
  bankReturnImports      BankReturnImport[]
  bankReturnImportItems  BankReturnImportItem[]
  cashSessions           CashSession[]
  cashMovements          CashMovement[]
  settlements            InstallmentSettlement[]

  @@unique([sourceSystem, sourceTenantId])
  @@index([name])
  @@map("companies")
}

model Product {
  id              String   @id @default(uuid())
  companyId       String
  status          String   @default("ACTIVE")
  name            String
  internalCode    String?
  sku             String?
  barcode         String?
  unitCode        String   @default("UN")
  productType     String   @default("GOODS")
  tracksInventory Boolean  @default(true)
  allowFraction   Boolean  @default(false)
  currentStock    Float    @default(0)
  minimumStock    Float    @default(0)
  purchasePrice   Float?
  salePrice       Float?
  ncmCode         String?
  cestCode        String?
  notes           String?
  createdAt       DateTime @default(now())
  createdBy       String?
  updatedAt       DateTime @updatedAt
  updatedBy       String?
  canceledAt      DateTime?
  canceledBy      String?

  company Company @relation(fields: [companyId], references: [id], onDelete: Restrict)
  payableInvoiceImportItems PayableInvoiceImportItem[]
  stockMovements            StockMovement[]

  @@unique([companyId, internalCode])
  @@unique([companyId, sku])
  @@unique([companyId, barcode])
  @@index([companyId, status, name])
  @@index([companyId, productType, tracksInventory])
  @@map("products")
}

model FiscalCertificate {
  id                  String   @id @default(uuid())
  companyId           String
  status              String   @default("ACTIVE")
  certificateType     String   @default("A1")
  environment         String   @default("PRODUCTION")
  purpose             String   @default("NFE_DFE")
  isDefault           Boolean  @default(false)
  aliasName           String
  authorStateCode     String
  holderName          String
  holderDocument      String
  serialNumber        String?
  thumbprint          String?
  validFrom           DateTime?
  validTo             DateTime?
  pfxEncryptedBase64  String
  passwordEncrypted   String
  lastNsu             String?
  lastMaxNsu          String?
  lastSyncAt          DateTime?
  lastSyncStatus      String?
  lastSyncMessage     String?
  createdAt           DateTime @default(now())
  createdBy           String?
  updatedAt           DateTime @updatedAt
  updatedBy           String?
  canceledAt          DateTime?
  canceledBy          String?

  company               Company               @relation(fields: [companyId], references: [id], onDelete: Restrict)
  payableInvoiceImports PayableInvoiceImport[]

  @@index([companyId, status, environment, purpose, aliasName])
  @@map("fiscal_certificates")
}

model Supplier {
  id                String   @id @default(uuid())
  companyId         String
  status            String   @default("ACTIVE")
  legalName         String
  tradeName         String?
  document          String?
  stateRegistration String?
  email             String?
  phone             String?
  notes             String?
  createdAt         DateTime @default(now())
  createdBy         String?
  updatedAt         DateTime @updatedAt
  updatedBy         String?
  canceledAt        DateTime?
  canceledBy        String?

  company               Company               @relation(fields: [companyId], references: [id], onDelete: Restrict)
  payableInvoiceImports PayableInvoiceImport[]
  payableTitles         PayableTitle[]

  @@unique([companyId, document])
  @@index([companyId, status, legalName])
  @@map("suppliers")
}

model PayableInvoiceImport {
  id                  String   @id @default(uuid())
  companyId           String
  supplierId          String?
  fiscalCertificateId String?
  status              String   @default("PENDING_APPROVAL")
  importType          String   @default("XML_UPLOAD")
  documentModel       String
  accessKey           String
  invoiceNumber       String
  series              String?
  operationNature     String?
  issueDate           DateTime
  entryDate           DateTime?
  totalProductsAmount Float    @default(0)
  totalInvoiceAmount  Float    @default(0)
  xmlHash             String
  xmlContentBlob      Bytes
  distributionNsu     String?
  parsedSnapshotJson  String?
  approvalNotes       String?
  approvedAt          DateTime?
  approvedBy          String?
  createdAt           DateTime @default(now())
  createdBy           String?
  updatedAt           DateTime @updatedAt
  updatedBy           String?
  canceledAt          DateTime?
  canceledBy          String?

  company     Company                      @relation(fields: [companyId], references: [id], onDelete: Restrict)
  supplier    Supplier?                    @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  fiscalCertificate FiscalCertificate?     @relation(fields: [fiscalCertificateId], references: [id], onDelete: SetNull)
  items       PayableInvoiceImportItem[]
  installments PayableInvoiceImportInstallment[]
  payableTitle PayableTitle?
  stockMovements StockMovement[]

  @@unique([companyId, accessKey])
  @@unique([companyId, xmlHash])
  @@index([companyId, status, issueDate])
  @@index([companyId, invoiceNumber, series])
  @@index([fiscalCertificateId, distributionNsu])
  @@map("payable_invoice_imports")
}

model PayableInvoiceImportItem {
  id                  String   @id @default(uuid())
  invoiceImportId     String
  productId           String?
  lineNumber          Int
  approvalAction      String?
  supplierItemCode    String?
  barcode             String?
  description         String
  ncmCode             String?
  cfopCode            String?
  unitCode            String?
  quantity            Float    @default(0)
  unitPrice           Float    @default(0)
  totalPrice          Float    @default(0)
  tracksInventory     Boolean  @default(true)
  createdAt           DateTime @default(now())
  createdBy           String?
  updatedAt           DateTime @updatedAt
  updatedBy           String?
  canceledAt          DateTime?
  canceledBy          String?

  invoiceImport  PayableInvoiceImport @relation(fields: [invoiceImportId], references: [id], onDelete: Restrict)
  product        Product?             @relation(fields: [productId], references: [id], onDelete: SetNull)
  stockMovements StockMovement[]

  @@unique([invoiceImportId, lineNumber])
  @@index([productId])
  @@map("payable_invoice_import_items")
}

model PayableInvoiceImportInstallment {
  id              String   @id @default(uuid())
  invoiceImportId String
  installmentLabel String?
  installmentNumber Int
  dueDate         DateTime
  amount          Float    @default(0)
  createdAt       DateTime @default(now())
  createdBy       String?
  updatedAt       DateTime @updatedAt
  updatedBy       String?
  canceledAt      DateTime?
  canceledBy      String?

  invoiceImport PayableInvoiceImport @relation(fields: [invoiceImportId], references: [id], onDelete: Restrict)

  @@unique([invoiceImportId, installmentNumber])
  @@index([dueDate])
  @@map("payable_invoice_import_installments")
}

model PayableTitle {
  id                     String   @id @default(uuid())
  companyId              String
  supplierId             String?
  sourceDocumentType     String
  sourceDocumentId       String   @unique
  status                 String   @default("OPEN")
  documentNumber         String
  description            String
  issueDate              DateTime
  totalAmount            Float    @default(0)
  supplierNameSnapshot   String
  supplierDocumentSnapshot String?
  createdAt              DateTime @default(now())
  createdBy              String?
  updatedAt              DateTime @updatedAt
  updatedBy              String?
  canceledAt             DateTime?
  canceledBy             String?

  company      Company              @relation(fields: [companyId], references: [id], onDelete: Restrict)
  supplier     Supplier?            @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  sourceImport PayableInvoiceImport @relation(fields: [sourceDocumentId], references: [id], onDelete: Restrict)
  installments PayableInstallment[]

  @@unique([companyId, sourceDocumentType, sourceDocumentId])
  @@index([companyId, status, issueDate])
  @@map("payable_titles")
}

model PayableInstallment {
  id                    String   @id @default(uuid())
  companyId             String
  titleId               String
  installmentNumber     Int
  installmentCount      Int
  dueDate               DateTime
  amount                Float    @default(0)
  openAmount            Float    @default(0)
  paidAmount            Float    @default(0)
  status                String   @default("OPEN")
  descriptionSnapshot   String
  supplierNameSnapshot  String
  supplierDocumentSnapshot String?
  createdAt             DateTime @default(now())
  createdBy             String?
  updatedAt             DateTime @updatedAt
  updatedBy             String?
  canceledAt            DateTime?
  canceledBy            String?

  company Company      @relation(fields: [companyId], references: [id], onDelete: Restrict)
  title   PayableTitle @relation(fields: [titleId], references: [id], onDelete: Restrict)

  @@unique([titleId, installmentNumber])
  @@index([companyId, status, dueDate])
  @@map("payable_installments")
}

model StockMovement {
  id                String   @id @default(uuid())
  companyId         String
  productId         String
  sourceImportId    String
  sourceImportItemId String
  movementType      String
  quantity          Float    @default(0)
  previousStock     Float    @default(0)
  resultingStock    Float    @default(0)
  unitCost          Float?
  notes             String?
  occurredAt        DateTime
  createdAt         DateTime @default(now())
  createdBy         String?
  updatedAt         DateTime @updatedAt
  updatedBy         String?
  canceledAt        DateTime?
  canceledBy        String?

  company        Company                  @relation(fields: [companyId], references: [id], onDelete: Restrict)
  product        Product                  @relation(fields: [productId], references: [id], onDelete: Restrict)
  sourceImport   PayableInvoiceImport     @relation(fields: [sourceImportId], references: [id], onDelete: Restrict)
  sourceImportItem PayableInvoiceImportItem @relation(fields: [sourceImportItemId], references: [id], onDelete: Restrict)

  @@index([companyId, occurredAt])
  @@index([productId, occurredAt])
  @@index([sourceImportId])
  @@map("stock_movements")
}

model BankAccount {
  id                  String   @id @default(uuid())
  companyId           String
  status              String   @default("ACTIVE")
  bankCode            String
  bankName            String
  branchNumber        String
  branchDigit         String   @default("")
  accountNumber       String
  accountDigit        String   @default("")
  walletCode          String?
  agreementCode       String?
  pixKey              String?
  beneficiaryName     String?
  beneficiaryDocument String?
  billingProvider              String?
  billingEnvironment           String?
  billingApiClientId           String?
  billingApiClientSecret       String?
  billingCertificateBase64     String?
  billingCertificatePassword   String?
  billingBeneficiaryCode       String?
  billingWalletVariation       String?
  billingContractNumber        String?
  billingModalityCode          String?
  billingDocumentSpeciesCode   String?
  billingAcceptanceCode        String?
  billingIssueTypeCode         String?
  billingDistributionTypeCode  String?
  billingNextBoletoNumber      Int?
  billingRegisterPixCode       Int?
  billingInstructionLine1      String?
  billingInstructionLine2      String?
  billingDefaultFinePercent    Float?
  billingDefaultInterestPercent Float?
  billingDefaultDiscountPercent Float?
  billingProtestDays           Int?
  billingNegativeDays          Int?
  notes               String?
  createdAt           DateTime @default(now())
  createdBy           String?
  updatedAt           DateTime @updatedAt
  updatedBy           String?
  canceledAt          DateTime?
  canceledBy          String?

  company               Company                @relation(fields: [companyId], references: [id], onDelete: Restrict)
  bankReturnImports     BankReturnImport[]
  bankReturnImportItems BankReturnImportItem[]

  @@index([companyId, status, bankName])
  @@unique([companyId, bankCode, branchNumber, branchDigit, accountNumber, accountDigit])
  @@map("bank_accounts")
}

model Party {
  id                 String    @id @default(uuid())
  companyId          String
  externalEntityType String
  externalEntityId   String
  name               String
  document           String?
  email              String?
  phone              String?
  addressLine1       String?
  neighborhood       String?
  city               String?
  state              String?
  postalCode         String?
  createdAt          DateTime  @default(now())
  createdBy          String?
  updatedAt          DateTime  @updatedAt
  updatedBy          String?
  canceledAt         DateTime?
  canceledBy         String?

  company          Company           @relation(fields: [companyId], references: [id], onDelete: Restrict)
  receivableTitles ReceivableTitle[]

  @@unique([companyId, externalEntityType, externalEntityId])
  @@index([companyId, name])
  @@map("parties")
}

model ReceivableBatch {
  id               String    @id @default(uuid())
  companyId        String
  sourceSystem     String
  sourceTenantId   String
  sourceBatchType  String
  sourceBatchId    String
  referenceDate    DateTime?
  status           String    @default("PROCESSED")
  itemCount        Int       @default(0)
  processedCount   Int       @default(0)
  duplicateCount   Int       @default(0)
  errorCount       Int       @default(0)
  payloadSnapshot  String?
  metadataJson     String?
  skippedItemsJson String?
  createdAt        DateTime  @default(now())
  createdBy        String?
  updatedAt        DateTime  @updatedAt
  updatedBy        String?
  canceledAt       DateTime?
  canceledBy       String?

  company                Company                 @relation(fields: [companyId], references: [id], onDelete: Restrict)
  receivableTitles       ReceivableTitle[]
  receivableInstallments ReceivableInstallment[]

  @@unique([companyId, sourceBatchId])
  @@index([companyId, createdAt])
  @@index([sourceSystem, sourceTenantId])
  @@map("receivable_batches")
}

model ReceivableTitle {
  id                    String    @id @default(uuid())
  companyId             String
  batchId               String
  payerPartyId          String?
  sourceEntityType      String
  sourceEntityId        String
  sourceEntityName      String?
  classLabel            String?
  businessKey           String
  description           String
  categoryCode          String?
  totalAmount           Float     @default(0)
  payerNameSnapshot     String
  payerDocumentSnapshot String?
  payerEmailSnapshot    String?
  payerPhoneSnapshot    String?
  createdAt             DateTime  @default(now())
  createdBy             String?
  updatedAt             DateTime  @updatedAt
  updatedBy             String?
  canceledAt            DateTime?
  canceledBy            String?

  company      Company                 @relation(fields: [companyId], references: [id], onDelete: Restrict)
  batch        ReceivableBatch         @relation(fields: [batchId], references: [id], onDelete: Restrict)
  payerParty   Party?                  @relation(fields: [payerPartyId], references: [id], onDelete: SetNull)
  installments ReceivableInstallment[]

  @@unique([companyId, businessKey])
  @@index([companyId, sourceEntityType, sourceEntityId])
  @@index([batchId])
  @@map("receivable_titles")
}

model ReceivableInstallment {
  id                    String    @id @default(uuid())
  companyId             String
  batchId               String
  titleId               String
  bankAccountId         String?
  bankAccountLabel      String?
  bankAssignedAt        DateTime?
  bankAssignedBy        String?
  bankSlipStatus        String?
  bankSlipMessage       String?
  bankSlipProvider      String?
  bankSlipOurNumber     String?
  bankSlipYourNumber    String?
  bankSlipDigitableLine String?
  bankSlipBarcode       String?
  bankSlipQrCode        String?
  bankSlipPdfBase64     String?
  bankSlipPayloadJson   String?
  bankSlipResponseJson  String?
  bankSlipIssuedAt      DateTime?
  bankSlipIssuedBy      String?
  sourceInstallmentKey  String
  installmentNumber     Int
  installmentCount      Int
  dueDate               DateTime
  amount                Float
  openAmount            Float
  paidAmount            Float     @default(0)
  interestRate          Float?
  interestGracePeriod   Int?
  penaltyRate           Float?
  penaltyValue          Float?
  penaltyGracePeriod    Int?
  status                String    @default("OPEN")
  settlementMethod      String?
  settledAt             DateTime?
  descriptionSnapshot   String
  payerNameSnapshot     String
  payerDocumentSnapshot String?
  createdAt             DateTime  @default(now())
  createdBy             String?
  updatedAt             DateTime  @updatedAt
  updatedBy             String?
  canceledAt            DateTime?
  canceledBy            String?

  company     Company                 @relation(fields: [companyId], references: [id], onDelete: Restrict)
  batch       ReceivableBatch         @relation(fields: [batchId], references: [id], onDelete: Restrict)
  title       ReceivableTitle         @relation(fields: [titleId], references: [id], onDelete: Restrict)
  settlements InstallmentSettlement[]
  bankReturnImportItems BankReturnImportItem[] @relation("BankReturnImportItemInstallment")

  @@unique([companyId, sourceInstallmentKey])
  @@index([companyId, status, dueDate])
  @@index([companyId, bankAccountId, status])
  @@index([titleId])
  @@map("receivable_installments")
}

model CashSession {
  id                    String    @id @default(uuid())
  companyId             String
  sourceSystem          String
  sourceTenantId        String
  cashierUserId         String
  cashierDisplayName    String
  status                String    @default("OPEN")
  openingAmount         Float     @default(0)
  totalReceivedAmount   Float     @default(0)
  expectedClosingAmount Float     @default(0)
  declaredClosingAmount Float?
  openedAt              DateTime  @default(now())
  closedAt              DateTime?
  notes                 String?
  createdAt             DateTime  @default(now())
  createdBy             String?
  updatedAt             DateTime  @updatedAt
  updatedBy             String?
  canceledAt            DateTime?
  canceledBy            String?

  company     Company                 @relation(fields: [companyId], references: [id], onDelete: Restrict)
  movements   CashMovement[]
  settlements InstallmentSettlement[]

  @@index([companyId, cashierUserId, status])
  @@index([companyId, openedAt])
  @@map("cash_sessions")
}

model CashMovement {
  id            String    @id @default(uuid())
  companyId     String
  cashSessionId String
  movementType  String
  direction     String
  paymentMethod String?
  amount        Float
  description   String
  occurredAt    DateTime
  referenceType String?
  referenceId   String?
  createdAt     DateTime  @default(now())
  createdBy     String?
  updatedAt     DateTime  @updatedAt
  updatedBy     String?
  canceledAt    DateTime?
  canceledBy    String?

  company     Company     @relation(fields: [companyId], references: [id], onDelete: Restrict)
  cashSession CashSession @relation(fields: [cashSessionId], references: [id], onDelete: Restrict)

  @@index([companyId, occurredAt])
  @@index([cashSessionId])
  @@map("cash_movements")
}

model InstallmentSettlement {
  id             String    @id @default(uuid())
  companyId      String
  installmentId  String
  cashSessionId  String
  receivedAmount Float
  discountAmount Float     @default(0)
  interestAmount Float     @default(0)
  penaltyAmount  Float     @default(0)
  paymentMethod  String
  settledAt      DateTime  @default(now())
  requestedBy    String?
  notes          String?
  createdAt      DateTime  @default(now())
  createdBy      String?
  updatedAt      DateTime  @updatedAt
  updatedBy      String?
  canceledAt     DateTime?
  canceledBy     String?

  company     Company               @relation(fields: [companyId], references: [id], onDelete: Restrict)
  installment ReceivableInstallment @relation(fields: [installmentId], references: [id], onDelete: Restrict)
  cashSession CashSession           @relation(fields: [cashSessionId], references: [id], onDelete: Restrict)
  bankReturnImportItems BankReturnImportItem[] @relation("BankReturnImportItemSettlement")

  @@index([companyId, settledAt])
  @@index([installmentId])
  @@index([cashSessionId])
  @@map("installment_settlements")
}

model BankReturnImport {
  id                 String   @id @default(uuid())
  companyId          String
  bankAccountId      String
  provider           String
  periodStart        DateTime
  periodEnd          DateTime
  importedItemCount  Int      @default(0)
  matchedItemCount   Int      @default(0)
  liquidatedItemCount Int     @default(0)
  bankClosedItemCount Int     @default(0)
  readyToApplyCount  Int      @default(0)
  appliedItemCount   Int      @default(0)
  unmatchedItemCount Int      @default(0)
  status             String   @default("IMPORTED")
  requestSnapshotJson String?
  summaryJson        String?
  createdAt          DateTime @default(now())
  createdBy          String?
  updatedAt          DateTime @updatedAt
  updatedBy          String?
  canceledAt         DateTime?
  canceledBy         String?

  company     Company              @relation(fields: [companyId], references: [id], onDelete: Restrict)
  bankAccount BankAccount          @relation(fields: [bankAccountId], references: [id], onDelete: Restrict)
  items       BankReturnImportItem[]

  @@index([companyId, createdAt])
  @@index([bankAccountId, createdAt])
  @@map("bank_return_imports")
}

model BankReturnImportItem {
  id                  String    @id @default(uuid())
  importId            String
  companyId           String
  bankAccountId       String
  matchedInstallmentId String?
  appliedSettlementId String?
  movementTypeCode    String
  movementStatus      String
  externalRequestCode String?
  externalFileId      String?
  dueDate             DateTime?
  movementDate        DateTime?
  paymentDate         DateTime?
  expectedCreditDate  DateTime?
  ourNumber           String?
  yourNumber          String?
  barcode             String?
  contractNumber      String?
  amount              Float     @default(0)
  settledAmount       Float?
  discountAmount      Float?
  interestAmount      Float?
  feeAmount           Float?
  rawPayloadJson      String
  appliedAt           DateTime?
  appliedBy           String?
  appliedStatus       String?
  createdAt           DateTime  @default(now())
  createdBy           String?
  updatedAt           DateTime  @updatedAt
  updatedBy           String?
  canceledAt          DateTime?
  canceledBy          String?

  importSession      BankReturnImport       @relation(fields: [importId], references: [id], onDelete: Restrict)
  company            Company                @relation(fields: [companyId], references: [id], onDelete: Restrict)
  bankAccount        BankAccount            @relation(fields: [bankAccountId], references: [id], onDelete: Restrict)
  matchedInstallment ReceivableInstallment? @relation("BankReturnImportItemInstallment", fields: [matchedInstallmentId], references: [id], onDelete: SetNull)
  appliedSettlement  InstallmentSettlement? @relation("BankReturnImportItemSettlement", fields: [appliedSettlementId], references: [id], onDelete: SetNull)

  @@index([importId, movementStatus])
  @@index([companyId, bankAccountId, movementStatus])
  @@index([matchedInstallmentId])
  @@map("bank_return_import_items")
}
