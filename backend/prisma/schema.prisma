  periodStart         DateTime
  periodEnd           DateTime
  importedItemCount   Int       @default(0)
  matchedItemCount    Int       @default(0)
  liquidatedItemCount Int       @default(0)
  bankClosedItemCount Int       @default(0)
  readyToApplyCount   Int       @default(0)
  appliedItemCount    Int       @default(0)
  unmatchedItemCount  Int       @default(0)
  status              String    @default("IMPORTED")
  requestSnapshotJson String?
  summaryJson         String?
  createdAt           DateTime  @default(now())
  createdBy           String?
  updatedAt           DateTime  @updatedAt
  updatedBy           String?
  canceledAt          DateTime?
  canceledBy          String?

  company     Company                @relation(fields: [companyId], references: [id], onDelete: Restrict)
  bankAccount BankAccount            @relation(fields: [bankAccountId], references: [id], onDelete: Restrict)
  items       BankReturnImportItem[]

  @@index([companyId, createdAt])
  @@index([bankAccountId, createdAt])
  @@map("bank_return_imports")
}

model BankReturnImportItem {
  id                   String    @id @default(uuid())
  importId             String
  companyId            String
  branchCode           Int       @default(1)
  bankAccountId        String
  matchedInstallmentId String?
  appliedSettlementId  String?
  movementTypeCode     String
  movementStatus       String
  externalRequestCode  String?
  externalFileId       String?
  dueDate              DateTime?
  movementDate         DateTime?
  paymentDate          DateTime?
  expectedCreditDate   DateTime?
  ourNumber            String?
  yourNumber           String?
  barcode              String?
  contractNumber       String?
  amount               Float     @default(0)
  settledAmount        Float?
  discountAmount       Float?
  interestAmount       Float?
  feeAmount            Float?
  rawPayloadJson       String
  appliedAt            DateTime?
  appliedBy            String?
  appliedStatus        String?
  createdAt            DateTime  @default(now())
  createdBy            String?
  updatedAt            DateTime  @updatedAt
  updatedBy            String?
  canceledAt           DateTime?
  canceledBy           String?

  importSession      BankReturnImport       @relation(fields: [importId], references: [id], onDelete: Restrict)
  company            Company                @relation(fields: [companyId], references: [id], onDelete: Restrict)
  bankAccount        BankAccount            @relation(fields: [bankAccountId], references: [id], onDelete: Restrict)
  matchedInstallment ReceivableInstallment? @relation("BankReturnImportItemInstallment", fields: [matchedInstallmentId], references: [id], onDelete: SetNull)
  appliedSettlement  InstallmentSettlement? @relation("BankReturnImportItemSettlement", fields: [appliedSettlementId], references: [id], onDelete: SetNull)

  @@index([importId, movementStatus])
  @@index([companyId, bankAccountId, movementStatus])
  @@index([matchedInstallmentId])
  @@map("bank_return_import_items")
}

model BankStatementImport {
  id                     String    @id @default(uuid())
  companyId              String
  branchCode             Int       @default(1)
  bankAccountId          String
  provider               String
  periodStart            DateTime
  periodEnd              DateTime
  pulledAt               DateTime  @default(now())
  importedMovementCount  Int       @default(0)
  createdMovementCount   Int       @default(0)
  duplicateMovementCount Int       @default(0)
  creditAmount           Float     @default(0)
  debitAmount            Float     @default(0)
  currentBalance         Float?
  status                 String    @default("IMPORTED")
  requestSnapshotJson    String?
  summaryJson            String?
  createdAt              DateTime  @default(now())
  createdBy              String?
  updatedAt              DateTime  @updatedAt
  updatedBy              String?
  canceledAt             DateTime?
  canceledBy             String?

  company        Company                 @relation(fields: [companyId], references: [id], onDelete: Restrict)
  bankAccount    BankAccount             @relation(fields: [bankAccountId], references: [id], onDelete: Restrict)
  firstMovements BankStatementMovement[] @relation("BankStatementFirstImport")
  lastMovements  BankStatementMovement[] @relation("BankStatementLastImport")

  @@index([companyId, createdAt])
  @@index([bankAccountId, pulledAt])
  @@index([companyId, bankAccountId, periodStart, periodEnd])
  @@map("bank_statement_imports")
}

model BankStatementMovement {
  id                   String    @id @default(uuid())
  companyId            String
  branchCode           Int       @default(1)
  bankAccountId        String
  firstImportId        String
  lastImportId         String
  provider             String
  externalId           String
  occurredAt           DateTime
  description          String
  documentNumber       String?
  movementType         String
  amount               Float     @default(0)
  balanceAfter         Float?
  reconciliationStatus String    @default("PENDING")
  reviewStatus         String    @default("NOT_REVIEWED")
  reviewedAt           DateTime?
  reviewedBy           String?
  rawPayloadJson       String
  createdAt            DateTime  @default(now())
  createdBy            String?
  updatedAt            DateTime  @updatedAt
  updatedBy            String?
  canceledAt           DateTime?
  canceledBy           String?

  company     Company             @relation(fields: [companyId], references: [id], onDelete: Restrict)
  bankAccount BankAccount         @relation(fields: [bankAccountId], references: [id], onDelete: Restrict)
  firstImport BankStatementImport @relation("BankStatementFirstImport", fields: [firstImportId], references: [id], onDelete: Restrict)
  lastImport  BankStatementImport @relation("BankStatementLastImport", fields: [lastImportId], references: [id], onDelete: Restrict)

  @@unique([companyId, bankAccountId, externalId])
  @@index([companyId, bankAccountId, occurredAt])
  @@index([companyId, bankAccountId, reconciliationStatus])
  @@index([companyId, bankAccountId, reviewStatus])
  @@index([firstImportId])
  @@index([lastImportId])
  @@map("bank_statement_movements")
}
