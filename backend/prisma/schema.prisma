  bankReturnImportItems BankReturnImportItem[]  @relation("BankReturnImportItemInstallment")

  @@unique([companyId, branchCode, sourceInstallmentKey])
  @@index([companyId, status, dueDate])
  @@index([companyId, bankAccountId, status])
  @@index([companyId, bankAccountId, bankMovementStatus])
  @@index([companyId, bankMovementGroupId])
  @@index([titleId])
  @@map("receivable_installments")
}

model CashSession {
  id                    String    @id @default(uuid())
  companyId             String
  branchCode            Int       @default(1)
  sourceSystem          String
  sourceTenantId        String
  cashierUserId         String
  cashierDisplayName    String
  status                String    @default("OPEN")
  openingAmount         Float     @default(0)
  totalReceivedAmount   Float     @default(0)
  expectedClosingAmount Float     @default(0)
  declaredClosingAmount Float?
  openedAt              DateTime  @default(now())
  closedAt              DateTime?
  notes                 String?
  createdAt             DateTime  @default(now())
  createdBy             String?
  updatedAt             DateTime  @updatedAt
  updatedBy             String?
  canceledAt            DateTime?
  canceledBy            String?

  company      Company                 @relation(fields: [companyId], references: [id], onDelete: Restrict)
  movements    CashMovement[]
  settlements  InstallmentSettlement[]
  salePayments SalePayment[]

  @@index([companyId, cashierUserId, status])
  @@index([companyId, openedAt])
  @@map("cash_sessions")
}

model CashMovement {
  id                  String    @id @default(uuid())
  companyId           String
  branchCode          Int       @default(1)
  cashSessionId       String
  movementType        String
  direction           String
  paymentMethod       String?
  bankAccountId       String?
  bankAccountLabel    String?
  bankMovementGroupId String?
  amount              Float
  description         String
  occurredAt          DateTime
  referenceType       String?
  referenceId         String?
  createdAt           DateTime  @default(now())
  createdBy           String?
  updatedAt           DateTime  @updatedAt
  updatedBy           String?
  canceledAt          DateTime?
  canceledBy          String?

  company     Company     @relation(fields: [companyId], references: [id], onDelete: Restrict)
  cashSession CashSession @relation(fields: [cashSessionId], references: [id], onDelete: Restrict)

  @@index([companyId, occurredAt])
  @@index([companyId, bankAccountId, bankMovementGroupId])
  @@index([cashSessionId])
  @@map("cash_movements")
}

model InstallmentSettlement {
  id                    String    @id @default(uuid())
  companyId             String
  branchCode            Int       @default(1)
  installmentId         String
  cashSessionId         String
  settlementGroupId     String?
  receivedAmount        Float
  discountAmount        Float     @default(0)
  interestAmount        Float     @default(0)
  penaltyAmount         Float     @default(0)
  paymentMethod         String
  bankAccountId         String?
  bankAccountLabel      String?
  bankMovementGroupId   String?
  superTefPaymentId     String?
  receivablePixIntentId String?
  settledAt             DateTime  @default(now())
  requestedBy           String?
  notes                 String?
  createdAt             DateTime  @default(now())
  createdBy             String?
  updatedAt             DateTime  @updatedAt
  updatedBy             String?
  canceledAt            DateTime?
  canceledBy            String?

  company               Company                @relation(fields: [companyId], references: [id], onDelete: Restrict)
  installment           ReceivableInstallment  @relation(fields: [installmentId], references: [id], onDelete: Restrict)
  cashSession           CashSession            @relation(fields: [cashSessionId], references: [id], onDelete: Restrict)
  superTefPayment       SuperTefPayment?       @relation(fields: [superTefPaymentId], references: [id], onDelete: Restrict)
  receivablePixIntent   ReceivablePixIntent?   @relation(fields: [receivablePixIntentId], references: [id], onDelete: Restrict)
  bankReturnImportItems BankReturnImportItem[] @relation("BankReturnImportItemSettlement")

  @@index([companyId, settledAt])
  @@index([companyId, settlementGroupId])
  @@index([companyId, bankAccountId, bankMovementGroupId])
  @@index([installmentId])
  @@index([cashSessionId])
  @@index([superTefPaymentId])
  @@index([receivablePixIntentId])
  @@map("installment_settlements")
}

model CustomerCredit {
  id               String    @id @default(uuid())
  companyId        String
  branchCode       Int       @default(1)
  partyId          String?
  customerName     String
  customerDocument String?
  status           String    @default("OPEN")
  originalAmount   Float
  availableAmount  Float
  sourceType       String    @default("MANUAL")
  sourceReference  String?
  notes            String?
  createdAt        DateTime  @default(now())
  createdBy        String?
  updatedAt        DateTime  @updatedAt
  updatedBy        String?
  canceledAt       DateTime?
  canceledBy       String?

  company     Company                  @relation(fields: [companyId], references: [id], onDelete: Restrict)
  movements   CustomerCreditMovement[]
  saleReturns SaleReturn[]

  @@index([companyId, status, customerName])
  @@index([companyId, customerDocument])
  @@map("customer_credits")
}

model CustomerCreditMovement {
  id            String    @id @default(uuid())
  companyId     String
  branchCode    Int       @default(1)
  creditId      String
  cashSessionId String?
  movementType  String
  direction     String
  amount        Float
  referenceType String?
  referenceId   String?
  notes         String?
  occurredAt    DateTime  @default(now())
  createdAt     DateTime  @default(now())
  createdBy     String?
  updatedAt     DateTime  @updatedAt
  updatedBy     String?
  canceledAt    DateTime?
  canceledBy    String?

  company Company        @relation(fields: [companyId], references: [id], onDelete: Restrict)
  credit  CustomerCredit @relation(fields: [creditId], references: [id], onDelete: Restrict)

  @@index([companyId, movementType, occurredAt])
  @@index([creditId, occurredAt])
  @@index([cashSessionId])
  @@map("customer_credit_movements")
}

model BankReturnImport {
  id                  String    @id @default(uuid())
  companyId           String
  branchCode          Int       @default(1)
  bankAccountId       String
  provider            String
  periodStart         DateTime
  periodEnd           DateTime
  importedItemCount   Int       @default(0)
  matchedItemCount    Int       @default(0)
  liquidatedItemCount Int       @default(0)
  bankClosedItemCount Int       @default(0)
  readyToApplyCount   Int       @default(0)
  appliedItemCount    Int       @default(0)
  unmatchedItemCount  Int       @default(0)
  status              String    @default("IMPORTED")
  requestSnapshotJson String?
  summaryJson         String?
  createdAt           DateTime  @default(now())
  createdBy           String?
  updatedAt           DateTime  @updatedAt
  updatedBy           String?
  canceledAt          DateTime?
  canceledBy          String?

  company     Company                @relation(fields: [companyId], references: [id], onDelete: Restrict)
  bankAccount BankAccount            @relation(fields: [bankAccountId], references: [id], onDelete: Restrict)
  items       BankReturnImportItem[]

  @@index([companyId, createdAt])
  @@index([bankAccountId, createdAt])
  @@map("bank_return_imports")
}

model BankReturnImportItem {
  id                   String    @id @default(uuid())
  importId             String
  companyId            String
  branchCode           Int       @default(1)
  bankAccountId        String
  matchedInstallmentId String?
  appliedSettlementId  String?
  movementTypeCode     String
  movementStatus       String
  externalRequestCode  String?
  externalFileId       String?
  dueDate              DateTime?
  movementDate         DateTime?
  paymentDate          DateTime?
  expectedCreditDate   DateTime?
  ourNumber            String?
  yourNumber           String?
  barcode              String?
  contractNumber       String?
  amount               Float     @default(0)
  settledAmount        Float?
  discountAmount       Float?
  interestAmount       Float?
  feeAmount            Float?
  rawPayloadJson       String
  appliedAt            DateTime?
  appliedBy            String?
  appliedStatus        String?
  createdAt            DateTime  @default(now())
  createdBy            String?
  updatedAt            DateTime  @updatedAt
  updatedBy            String?
  canceledAt           DateTime?
  canceledBy           String?

  importSession      BankReturnImport       @relation(fields: [importId], references: [id], onDelete: Restrict)
  company            Company                @relation(fields: [companyId], references: [id], onDelete: Restrict)
  bankAccount        BankAccount            @relation(fields: [bankAccountId], references: [id], onDelete: Restrict)
  matchedInstallment ReceivableInstallment? @relation("BankReturnImportItemInstallment", fields: [matchedInstallmentId], references: [id], onDelete: SetNull)
  appliedSettlement  InstallmentSettlement? @relation("BankReturnImportItemSettlement", fields: [appliedSettlementId], references: [id], onDelete: SetNull)

  @@index([importId, movementStatus])
  @@index([companyId, bankAccountId, movementStatus])
  @@index([matchedInstallmentId])
  @@map("bank_return_import_items")
}

model BankStatementImport {
  id                     String    @id @default(uuid())
  companyId              String
  branchCode             Int       @default(1)
  bankAccountId          String
  provider               String
  periodStart            DateTime
  periodEnd              DateTime
  pulledAt               DateTime  @default(now())
  importedMovementCount  Int       @default(0)
  createdMovementCount   Int       @default(0)
  duplicateMovementCount Int       @default(0)
  creditAmount           Float     @default(0)
  debitAmount            Float     @default(0)
  currentBalance         Float?
  status                 String    @default("IMPORTED")
  requestSnapshotJson    String?
  summaryJson            String?
  createdAt              DateTime  @default(now())
  createdBy              String?
  updatedAt              DateTime  @updatedAt
  updatedBy              String?
  canceledAt             DateTime?
  canceledBy             String?

  company        Company                 @relation(fields: [companyId], references: [id], onDelete: Restrict)
  bankAccount    BankAccount             @relation(fields: [bankAccountId], references: [id], onDelete: Restrict)
  firstMovements BankStatementMovement[] @relation("BankStatementFirstImport")
  lastMovements  BankStatementMovement[] @relation("BankStatementLastImport")

  @@index([companyId, createdAt])
  @@index([bankAccountId, pulledAt])
  @@index([companyId, bankAccountId, periodStart, periodEnd])
  @@map("bank_statement_imports")
}

model BankStatementMovement {
  id                   String    @id @default(uuid())
  companyId            String
  branchCode           Int       @default(1)
  bankAccountId        String
  firstImportId        String
  lastImportId         String
  provider             String
  externalId           String
  occurredAt           DateTime
  description          String
  documentNumber       String?
  movementType         String
  amount               Float     @default(0)
  balanceAfter         Float?
  reconciliationStatus String    @default("PENDING")
  reviewStatus         String    @default("NOT_REVIEWED")
  reviewedAt           DateTime?
  reviewedBy           String?
  rawPayloadJson       String
  createdAt            DateTime  @default(now())
  createdBy            String?
  updatedAt            DateTime  @updatedAt
  updatedBy            String?
  canceledAt           DateTime?
  canceledBy           String?

  company     Company             @relation(fields: [companyId], references: [id], onDelete: Restrict)
  bankAccount BankAccount         @relation(fields: [bankAccountId], references: [id], onDelete: Restrict)
  firstImport BankStatementImport @relation("BankStatementFirstImport", fields: [firstImportId], references: [id], onDelete: Restrict)
  lastImport  BankStatementImport @relation("BankStatementLastImport", fields: [lastImportId], references: [id], onDelete: Restrict)

  @@unique([companyId, bankAccountId, externalId])
  @@index([companyId, bankAccountId, occurredAt])
  @@index([companyId, bankAccountId, reconciliationStatus])
  @@index([companyId, bankAccountId, reviewStatus])
  @@index([firstImportId])
  @@index([lastImportId])
  @@map("bank_statement_movements")
}
