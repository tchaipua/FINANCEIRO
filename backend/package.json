{
  "name": "financeiro-backend",
  "version": "0.1.0",
  "private": true,
  "description": "Core financeiro multiempresa desacoplado",
  "scripts": {
    "prestart": "prisma generate",
    "prestart:dev": "prisma generate",
    "prestart:prod": "prisma generate",
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/main",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "test:core": "npm run build && node test/finance-core.test.cjs",
    "test:nfce": "npm run build && ts-node test/nfce-core.test.ts && node test/nfce-flow.test.cjs",
    "test:nfe": "npm run build && ts-node test/brazil-tax-id.test.ts && ts-node test/nfe-core.test.ts",
    "test:nfse": "npm run build && ts-node test/nfse-core.test.ts",
    "test:supertef": "npm run build && ts-node test/supertef-core.test.ts",
    "test:printing": "npm run build && ts-node test/printing-core.test.ts",
    "test:nfce:homologation": "ts-node scripts/nfce-homologation-smoke.ts",
    "sefaz:cadastro": "ts-node scripts/sefaz-cadastro-query.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1091.0",
    "@nestjs/common": "^10.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/swagger": "^7.3.0",
    "@prisma/client": "^5.10.2",
    "@xmldom/xmldom": "^0.9.10",
    "bwip-js": "^4.11.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "dotenv": "^16.6.1",
    "fast-xml-parser": "^5.7.3",
    "node-forge": "^1.4.0",
    "nodemailer": "^8.0.11",
    "pdfkit": "^0.19.1",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.1",
    "xml-crypto": "^6.1.2"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.0.0",
    "@nestjs/schematics": "^10.0.0",
    "@types/bwip-js": "^3.2.3",
    "@types/express": "^4.17.17",
    "@types/node": "^20.3.1",
    "@types/node-forge": "^1.3.14",
    "@types/nodemailer": "^7.0.12",
    "@types/pdfkit": "^0.17.6",
    "prisma": "^5.10.2",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.1.3"
  }
}
